{
  "name": "MTXCore",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "android:build": "cd android && ./gradlew assembleRelease",
    "start": "react-native start",
    "start:clean": "react-native start --reset-cache",
    "start:alt": "react-native start --port 8082",
    "android:alt": "cross-env REACT_NATIVE_PACKAGER_PORT=8082 react-native run-android",
    "test": "jest",
    "lint:rules": "eslint . --cache",
    "lint:code-format": "prettier --write \"{src,__mocks__}/**/*.{js,json,md,ts,tsx,yml,yaml}\"",
    "lint:type-check": "tsc",
    "lint": "eslint ./src --ext .js,.ts,.tsx,.jsx --fix",
    "lint:fix": "yarn lint:rules --fix && yarn lint:code-format --write && yarn lint:type-check",
    "generate:stickers": "node scripts/generateStickers.js",
    "test:apis": "node scripts/test-apis.mjs",
    "fix:sticker-folders": "node scripts/fixStickerFolders.js",
    "test:report": "jest --collectCoverage --coverageDirectory=\"./coverage\" --ci --reporters=default --reporters=jest-junit --coverage",
    "pod-install": "npx pod-install",
    "ios:clean": "cd ios && xcodebuild clean -workspace MTXCore.xcworkspace -scheme MyApp",
    "ios:open": "cd ios && open MTXCore.xcworkspace",
    "ios:archive": "cd ios && xcodebuild archive -workspace MTXCore.xcworkspace -scheme MyApp -configuration Release -archivePath build/MyApp.xcarchive -destination 'generic/platform=iOS'",
    "ios:build": "yarn ios:clean && yarn ios:archive",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
