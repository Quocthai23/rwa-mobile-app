    "@react-navigation/native": "^7.1.16",
    "@react-navigation/stack": "^7.4.4",
    "@shopify/flash-list": "^2.2.0",
    "@tanstack/react-query": "^5.84.0",
    "axios": "^1.13.4",
    "clsx": "^2.1.1",
